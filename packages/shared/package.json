{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./dist/index.js"
    },
    "./queue": {
      "types": "./queue.ts",
      "import": "./dist/queue.js"
    },
    "./prisma": {
      "types": "./prisma.ts",
      "import": "./dist/prisma.js"
    },
    "./types": {
      "types": "./types.ts",
      "import": "./dist/types.js"
    }
  },
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bullmq": "^5.73.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
