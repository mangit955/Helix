{
  "name": "@repo/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./model": {
      "types": "./src/model.ts",
      "import": "./dist/model.js"
    },
    "./prompts": {
      "types": "./src/prompts.ts",
      "import": "./dist/prompts.js"
    },
    "./context": {
      "types": "./src/context.ts",
      "import": "./dist/context.js"
    },
    "./verify": {
      "types": "./src/verify.ts",
      "import": "./dist/verify.js"
    },
    "./orchestrator": {
      "types": "./src/orchestrator.ts",
      "import": "./dist/orchestrator.js"
    }
  },
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@repo/executor": "workspace:*",
    "@repo/shared": "workspace:*",
    "@prisma/client": "^7.6.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
