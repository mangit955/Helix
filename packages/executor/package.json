{
  "name": "@repo/executor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./workspace": {
      "types": "./src/workspace.ts",
      "import": "./dist/workspace.js"
    },
    "./editor": {
      "types": "./src/editor.ts",
      "import": "./dist/editor.js"
    },
    "./command-runner": {
      "types": "./src/command-runner.ts",
      "import": "./dist/command-runner.js"
    },
    "./repo-scan": {
      "types": "./src/repo-scan.ts",
      "import": "./dist/repo-scan.js"
    }
  },
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@repo/shared": "workspace:*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
